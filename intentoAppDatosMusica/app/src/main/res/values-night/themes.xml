<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.IntentoAppDatosMusica" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->

        <!-- Colores de fondo y texto para modo oscuro -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_color_dark</item>
        <item name="colorSurface">@color/surface_color_dark</item>

        <!-- Disable the default ActionBar -->
        <item name="windowActionBar">false</item>
        <!-- Use a Toolbar instead -->
        <item name="windowNoTitle">true</item>

        <!-- Configuración para RadioButton -->
        <item name="radioButtonStyle">@style/RadioButtonTheme</item>

        <!-- Configuración para CheckBox -->
        <item name="checkboxStyle">@style/CheckBoxStyle</item>

        <!-- Color para controles (modo oscuro) -->
        <item name="colorControlNormal">@color/white</item>
        <item name="colorControlActivated">@color/purple_200</item>

        <item name="iconTint">@color/icon_color</item>
        <!-- ... otras configuraciones ... -->
        <item name="seekBarTrackColor">#424242</item> <!-- Gris oscuro -->
        <item name="seekBarProgressColor">#757575</item> <!-- Gris medio-claro -->

        <!-- Estilo para botones de diálogo en modo oscuro -->
        <item name="buttonBarPositiveButtonStyle">@style/AlertDialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/AlertDialog.Button.Negative</item>
        <item name="buttonBarNeutralButtonStyle">@style/AlertDialog.Button.Neutral</item>
    </style>

    <style name="RadioButtonTheme" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="buttonTint">@color/radio_button_tint_dark</item>
    </style>

    <style name="CheckBoxStyle" parent="Widget.MaterialComponents.CompoundButton.CheckBox">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="buttonTint">@color/check_box_tint_dark</item>
    </style>

    <!-- Estilos para los botones de diálogo -->
    <style name="AlertDialog.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/background_light</item>
    </style>

    <style name="AlertDialog.Button.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/background_light</item>
    </style>

    <style name="AlertDialog.Button.Neutral" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/background_light</item>
    </style>
</resources>