<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Clima Grupal (Grid) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clima Grupal"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGridClimaGrupal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <!-- Descripción -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary"/>

        <EditText
            android:id="@+id/etObservacionesDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="4"
            android:gravity="top|start"
            android:background="@drawable/bordered_background"
            android:padding="8dp"
            android:hint="Describa el clima y observaciones generales..."
            android:inputType="textMultiLine"
            android:layout_marginBottom="24dp"
            android:textColor="?android:attr/textColorPrimary"/>


        <!-- Participación (Ahora Calificación Global) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calificación de la Sesión"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary"/>
        
        <RatingBar
            android:id="@+id/ratingSesion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:numStars="5"
            android:stepSize="0.5"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comentarios adicionales"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorSecondary"/>

        <EditText
            android:id="@+id/etComentariosParticipacion"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:gravity="top|start"
            android:background="@drawable/bordered_background"
            android:padding="8dp"
            android:hint="Comentarios adicionales..."
            android:inputType="textMultiLine"
            android:textColor="?android:attr/textColorPrimary"/>


    </LinearLayout>
</ScrollView>
