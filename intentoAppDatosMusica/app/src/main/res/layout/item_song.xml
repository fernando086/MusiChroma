<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:id="@+id/mi_cardview"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:strokeWidth="6dp"
    app:strokeColor="@color/black">

    <!-- Contenedor para superponer elementos -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Barra de progreso (fondo, línea delgada) -->
        <SeekBar
            android:id="@+id/seekBar_progress"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:max="100"
            android:progressDrawable="@android:color/transparent"
            android:thumb="@drawable/custom_seekbar_thumb"
            android:visibility="invisible"
            android:thumbOffset="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp" />

        <!-- Contenido superpuesto encima de la barra de progreso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- Botón de reproducir/pausar -->
            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:padding="1dp"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/iconoplay"
                android:layout_gravity="center_vertical" />

            <!-- Contenedor para el resto de los elementos (nombre, autor, etc.) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:gravity="center_vertical">

                <!-- Nombre de la canción -->
                <TextView
                    android:id="@+id/tv_song_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre de la canción"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:paddingLeft="12dp"
                    android:ellipsize="end" />

                <!-- Contenedor horizontal para autor y tiempo de canción -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Autor de la canción -->
                    <TextView
                        android:id="@+id/tv_song_author"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Autor de la canción"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:singleLine="true"
                        android:scrollHorizontally="true"
                        android:paddingLeft="12dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <!-- Contador de tiempo (minutos y segundos) -->
                    <TextView
                        android:id="@+id/tv_song_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00 / 00:00"
                        android:textSize="12sp"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <!-- Botones de acciones (editar, eliminar, agregar imagen) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="8dp"
                    android:gravity="end"
                    android:orientation="horizontal" >

                    <ImageButton
                        android:id="@+id/btn_modify_song_data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="9dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/iconomodificar" />

                    <ImageButton
                        android:id="@+id/btn_delete"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="9dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/iconoeliminar" />

                    <ImageButton
                        android:id="@+id/btn_add_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="9dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/iconoagregarimagen" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>