<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Aquí va el contenido general -->
        <HorizontalScrollView
            android:id="@+id/submenuScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/layoutSubmenuSecciones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <!-- Aquí se agregarán dinámicamente los botones de cada sección -->
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/layoutContenidoSeccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="8dp">

            <!-- Área 1: SeekBar con contador central -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <SeekBar
                    android:id="@+id/seekBarSeccion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressDrawable="@drawable/seekbar_track"
                    android:thumb="@drawable/seekbar_thumb_datosmusic"
                    android:thumbOffset="0dp" />

                <TextView
                    android:id="@+id/tvProgresoSeccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="00:00"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Área 2: Control de tiempo y botones de navegación -->
            <LinearLayout
                android:id="@+id/controlesTiempo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvInicioSeccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:gravity="center_horizontal"
                    android:textColor="?android:attr/textColorPrimary" />

                <ImageButton
                    android:id="@+id/btnRetroceder5Seccion"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/iconoretrocedercancion"
                    android:scaleType="fitCenter"
                    android:contentDescription="Retroceder" />

                <ImageButton
                    android:id="@+id/btnPlayPauseSeccion"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/iconoplay"
                    android:scaleType="fitCenter"
                    android:contentDescription="Reproducir/Pausar" />

                <ImageButton
                    android:id="@+id/btnAdelantar5Seccion"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/iconoadelantarcancion"
                    android:scaleType="fitCenter"
                    android:contentDescription="Avanzar" />

                <TextView
                    android:id="@+id/tvFinSeccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="8dp"
                    android:text="00:00"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

            <!-- Área 3: Género + ComboBox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Género:"
                    android:textColor="?android:attr/textColorPrimary" />

                <Button
                    android:id="@+id/btnSeleccionarGeneros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccionar género"
                    android:layout_marginStart="16dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <!-- Área 4: Lista horizontal de géneros -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutGenerosSeleccionados"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Área 5: Texto comentario -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Comentario sobre la sección"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:layout_marginBottom="4dp" />

            <!-- Área 6: EditText comentario -->
            <EditText
                android:id="@+id/etComentarioSeccion"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:textColor="?android:attr/textColorPrimary"
                android:hint="¿Qué emociones sientes al escuchar esta sección musical?"
                android:backgroundTint="?attr/colorPrimary"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/checkboxSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="?attr/colorControlNormal"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:text="Publicar comentario de esta sección."
                android:textColor="?android:attr/textColorPrimary" />

            <!-- Área 7: Botón "Definir emociones" -->
            <LinearLayout
                android:id="@+id/btnDefinirEmociones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/boton_personalizado"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Definir emociones"
                    android:textColor="#000000"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/iconoplutchik"
                    android:layout_marginStart="8dp"
                    android:scaleType="fitCenter" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>

