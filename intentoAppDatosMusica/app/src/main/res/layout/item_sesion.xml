<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:id="@+id/mi_cardview"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:strokeWidth="6dp"
    app:strokeColor="@color/black">

    <!-- Contenedor para superponer elementos -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Contenido superpuesto encima de la barra de progreso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- Botón de reproducir/pausar -->
            <ImageButton
                android:id="@+id/btnIngresarSesion"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:padding="1dp"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/iconoentrar"
                android:layout_gravity="center_vertical" />

            <!-- Contenedor para el resto de los elementos (nombre, autor, etc.) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:gravity="center_vertical">

                <!-- Nombre de la canción -->
                <TextView
                    android:id="@+id/tvIDNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID - Nombre de la sesión"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:paddingLeft="12dp"
                    android:ellipsize="end" />

                <!-- Contenedor horizontal para autor y tiempo de canción -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Autor de la canción -->
                    <TextView
                        android:id="@+id/tvFechaSesion"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Fecha Hora Inicio - Fecha Hora Final"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:singleLine="true"
                        android:scrollHorizontally="true"
                        android:paddingEnd="16dp"
                        android:paddingStart="16dp"
                        android:paddingLeft="12dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <!-- Estrellas -->
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/iconoestrella" />

                    <TextView
                        android:id="@+id/tvEstrellas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:layout_marginEnd="16dp" />

                    <!-- Canciones -->
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/nota_musical" />

                    <TextView
                        android:id="@+id/tvCantidadCanciones"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12" />

                </LinearLayout>

                <!-- Botones de acciones (editar, eliminar, agregar imagen) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="8dp"
                    android:gravity="end"
                    android:orientation="horizontal" >

                    <ImageButton
                        android:id="@+id/btnClasificarColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="9dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/iconopaleta" />

                    <ImageButton
                        android:id="@+id/btnEliminarSesion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="9dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/iconoeliminar" />

                    <ImageButton
                        android:id="@+id/btnMarcarFavorito"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="9dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/iconocorazon" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>