<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/popup_background"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Selecciona algún color para buscar (puede ser más de uno a la vez)"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginTop="16dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="300dp">

        <!-- Capa inferior: la rueda -->
        <ImageView
            android:id="@+id/imagen_rueda_busqueda"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ruedafinal"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter" />

        <!-- Capa superior: los checks (transparente) -->
        <FrameLayout
            android:id="@+id/contenedor_checks_busqueda"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btnCancelarBusqueda"
            android:text="Cancelar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnAceptarBusqueda"
            android:text="Aceptar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
