<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_rueda"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Container for the wheel image and the checks overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imagen_rueda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/ruedafinal"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter" />

        <!-- ✅ Contenedor para todos los checks -->
        <FrameLayout
            android:id="@+id/contenedor_checks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

    <Button
        android:id="@+id/btn_buscar_palabras"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="Buscar palabra"
        android:textColor="@color/white"/>
</LinearLayout>
