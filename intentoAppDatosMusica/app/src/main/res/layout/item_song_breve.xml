<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:id="@+id/mi_cardview_breve"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:strokeWidth="6dp"
    app:strokeColor="@color/black">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- SeekBar (fondo de progreso de reproducción) -->
        <SeekBar
            android:id="@+id/seekBar_progress_breve"
            android:layout_width="match_parent"
            android:layout_height="67dp"
            android:layout_gravity="center"
            android:max="100"
            android:padding="0dp"
            android:progressDrawable="@android:color/transparent"
            android:thumb="@drawable/custom_seekbar_thumb"
            android:thumbOffset="0dp"
            android:visibility="invisible" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <!-- ✅ CheckBox de selección múltiple -->
            <CheckBox
                android:id="@+id/cbSeleccionar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp" />

            <!-- Botón de reproducir/pausar -->
            <ImageButton
                android:id="@+id/btn_play_pause_breve"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:padding="15dp"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/iconoplay" />

            <!-- Contenedor para texto -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/tv_song_name_breve"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre de la canción"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:singleLine="true"
                    android:scrollHorizontally="true"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="marquee" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_song_author_breve"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Autor de la canción"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:singleLine="true"
                        android:scrollHorizontally="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                </LinearLayout>
            </LinearLayout>

            <!-- Duración -->
            <TextView
                android:id="@+id/tv_song_duration_breve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="00:00 / 00:00"
                android:textSize="12sp" />

        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>