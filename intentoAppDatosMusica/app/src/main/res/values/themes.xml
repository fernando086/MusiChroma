<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.IntentoAppDatosMusica" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->

        <!-- Colores de fondo y texto -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:textColorPrimary">@color/text_color_light</item>
        <item name="colorSurface">@color/surface_color</item>

        <!-- Disable the default ActionBar -->
        <item name="windowActionBar">false</item>
        <!-- Use a Toolbar instead -->
        <item name="windowNoTitle">true</item>

        <!-- Configuración para RadioButton -->
        <item name="radioButtonStyle">@style/RadioButtonTheme</item>

        <!-- Configuración para CheckBox -->
        <item name="checkboxStyle">@style/CheckBoxStyle</item>

        <!-- Color para controles (también afecta a switches, etc.) -->
        <item name="colorControlNormal">@color/black</item>
        <item name="colorControlActivated">@color/purple_500</item>

        <item name="iconTint">@color/icon_color</item>
        <!-- ... otras configuraciones ... -->
        <item name="seekBarTrackColor">#E0E0E0</item> <!-- Gris claro -->
        <item name="seekBarProgressColor">#9E9E9E</item> <!-- Gris medio -->
    </style>

    <style name="RadioButtonTheme" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="buttonTint">@color/radio_button_tint</item>
    </style>

    <style name="CheckBoxStyle" parent="Widget.MaterialComponents.CompoundButton.CheckBox">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="buttonTint">@color/check_box_tint_dark</item>
    </style>

</resources>